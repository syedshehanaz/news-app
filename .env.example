# Prisma database connection
DATABASE_URL="file:./dev.db"

# GNews API key for live news fetching
# Get one at https://gnews.io/
GNEWS_API_KEY="your_gnews_api_key_here"

# Company/OpenAI API configuration for the AI chat assistant
COMPANY_API_KEY="your_api_key_here"
COMPANY_API_URL="https://api.your.com/v1/chat/completions"
COMPANY_AI_MODEL="company-model-name"
